STEAM_ACCOUNT_NAME=your_bot_account_name
STEAM_PASSWORD=your_bot_password

# Preferred: Mobile Authenticator shared secret (permanent, no email codes ever).
# Get this by running: steamguard-cli setup --username <account>
# Then copy the shared_secret value here.
STEAM_TOTP_SECRET=

# Fallback: email Steam Guard code (one-time, expires quickly).
# Only needed before steamguard-cli is set up.
STEAM_AUTH_CODE=

# Lobby settings
LOBBY_NAME=inhouse-poc
LOBBY_PASSWORD=test123
